# Supabase (required for auth: sign-up, sign-in, OTP)
# From your Supabase project: Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API server (optional; for authenticated API calls after login)
# Use your machine IP when testing on a physical device, e.g. http://192.168.1.100:4001
EXPO_PUBLIC_API_URL=http://localhost:4001
